<!DOCTYPE html>
<html>
<head>
  <title>Mood App</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body {
      font-family: Arial;
      text-align: center;
      background: #f0f4ff;
      padding: 40px;
    }
    .mood {
      font-size: 40px;
      margin: 10px;
      padding: 20px;
      border-radius: 15px;
      background: white;
      display: inline-block;
      cursor: pointer;
    }
    #action {
      margin-top: 30px;
      font-size: 22px;
    }
  </style>
</head>
<body>

<h2>How do you feel?</h2>

<div class="mood" onclick="showAction('Take a 5-minute rest')">😴</div>
<div class="mood" onclick="showAction('Drink water')">😞</div>
<div class="mood" onclick="showAction('Take deep breaths')">😵</div>
<div class="mood" onclick="showAction('Sit quietly')">😌</div>
<div class="mood" onclick="showAction('Do jumping jacks')">🤩</div>
<div class="mood" onclick="showAction('Go for a short walk')">😡</div>

<div id="action"></div>

<script>
function showAction(text) {
  document.getElementById("action").innerText = text;
}
</script>

</body>
</html>
